rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (request.auth.uid == 'w02kvOK1b0SiPGgmQRX3g34ArSt2' || request.auth.token.email == 'diopacific1@gmail.com');
    }

    match /{document=**} {
      allow read, write: if false;
    }

    // Guestbook (방명록 - 관리자 승인제)
    match /guestbook/{entryId} {
      allow read: if resource.data == null || resource.data.status == 'approved' || isAdmin();
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.nickname is string
                    && request.resource.data.message is string;
      allow update, delete: if isAdmin();
    }

    // 2. Personal Stories & Column writings
    match /stories/{storyId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 3. Plant garden journal entries
    match /plant_journal/{entryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 4. Admin Portfolio (Exclusive content)
    match /portfolio/{portfolioId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
