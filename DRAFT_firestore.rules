rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { 
      return request.auth != null && request.auth.token.email_verified == true; 
    }

    function isValidPlantJournalEntry(data) {
      return data.keys().hasAll(['userId', 'title', 'content', 'createdAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 50000
        && data.userId == request.auth.uid
        && (data.get('image', '') is string && data.get('image', '').size() <= 2000)
        && (data.get('tags', []) is list && data.get('tags', []).size() <= 20 && (data.get('tags', []).size() == 0 || data.get('tags', [])[0] is string))
        && (data.get('type', '') is string && data.get('type', '').size() <= 100)
        && (data.get('weather', '') is string && data.get('weather', '').size() <= 50)
        && (data.get('activity', '') is string && data.get('activity', '').size() <= 50)
        && (data.get('date', '') is string && data.get('date', '').size() <= 50)
        && data.createdAt is number
        && (data.get('updatedAt', 0) is number);
    }

    function isValidStoryPost(data) {
      return data.keys().hasAll(['userId', 'title', 'content', 'category', 'createdAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 50000
        && data.category is string && data.category.size() <= 50
        && data.userId == request.auth.uid
        && (data.get('image', '') is string && data.get('image', '').size() <= 2000)
        && (data.get('date', '') is string && data.get('date', '').size() <= 50)
        && (data.get('likes', 0) is number)
        && data.createdAt is number
        && (data.get('updatedAt', 0) is number);
    }

    match /plant_journals/{entryId} {
      allow read: if isSignedIn() && isValidId(entryId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(entryId) && isValidPlantJournalEntry(incoming()) 
        && incoming().createdAt == request.time.toMillis()
        && incoming().keys().size() <= 11;
      allow update: if isSignedIn() && isValidId(entryId) && isValidPlantJournalEntry(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time.toMillis()
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'image', 'tags', 'type', 'weather', 'activity', 'date', 'updatedAt']);
      allow delete: if isSignedIn() && isValidId(entryId) && existing().userId == request.auth.uid;
    }

    match /stories/{storyId} {
      allow read: if isSignedIn() && isValidId(storyId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(storyId) && isValidStoryPost(incoming()) 
        && incoming().createdAt == request.time.toMillis()
        && incoming().keys().size() <= 10;
      allow update: if isSignedIn() && isValidId(storyId) && isValidStoryPost(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && ( // Either updating post contents, or recording a like.
             (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'image', 'date', 'updatedAt']) && incoming().updatedAt == request.time.toMillis())
          || (incoming().diff(existing()).affectedKeys().hasOnly(['likes']))
        );
      allow delete: if isSignedIn() && isValidId(storyId) && existing().userId == request.auth.uid;
    }
  }
}
