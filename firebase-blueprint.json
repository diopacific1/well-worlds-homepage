{
  "entities": {
    "PlantJournalEntry": {
      "title": "PlantJournalEntry",
      "description": "An entry in the user's plant journal.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns the entry." },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string" },
        "weather": { "type": "string" },
        "activity": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "title", "content", "createdAt"]
    },
    "StoryPost": {
      "title": "StoryPost",
      "description": "A personal writing or story post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns the post." },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "likes": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "title", "content", "category", "createdAt"]
    }
  },
  "firestore": {
    "/plant_journals/{entryId}": {
      "schema": { "$ref": "#/entities/PlantJournalEntry" },
      "description": "Plant journal entries."
    },
    "/stories/{storyId}": {
      "schema": { "$ref": "#/entities/StoryPost" },
      "description": "Stories and personal writings."
    }
  }
}
